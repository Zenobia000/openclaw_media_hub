# OpenClaw 環境變數配置範例
# 將此檔案複製為 .env 並填寫您的數值

# --- 核心設定 ---
# 使用的 Docker 映像檔
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# --- 網路 ---
# 綁定環境：lan (預設), wan, 或 all
OPENCLAW_GATEWAY_BIND=lan

# 允許不安全的私用 WebSocket 連線 (true/false)
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=true

# --- 路徑與目錄 ---
# OpenClaw 配置的基礎目錄 (預設為 ~/.openclaw)
# OPENCLAW_CONFIG_DIR=./config

# 檔案與資料的工作區目錄 (預設為 ~/.openclaw/workspace)
# OPENCLAW_WORKSPACE_DIR=./workspace

# --- Playwright ---
# 如有需要，Playwright 瀏覽器的自定義路徑
# PLAYWRIGHT_BROWSERS_PATH=

# --- AI 服務 ---
# Anthropic API 金鑰 (用於 Claude 模型)
# 可至輸入 claude setup-token 取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here