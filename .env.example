# OpenClaw Environment Configuration Example
# Copy this file to .env and fill in your values

# --- Core Settings ---
# Docker image to use
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# --- Security ---
# Gateway secure token (required for CLI connection)
# Use a strong random string
OPENCLAW_GATEWAY_TOKEN=your_secure_token_here

# --- Network ---
# Binding environment: lan (default), wan, or all
OPENCLAW_GATEWAY_BIND=lan

# Allow insecure private WebSocket connections (true/false)
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=true

# --- Paths & Directories ---
# Base directory for OpenClaw configuration (defaults to ~/.openclaw)
# OPENCLAW_CONFIG_DIR=./config

# Workspace directory for files and data (defaults to ~/.openclaw/workspace)
# OPENCLAW_WORKSPACE_DIR=./workspace

# --- Playwright ---
# Custom path for Playwright browsers if needed
# PLAYWRIGHT_BROWSERS_PATH=
