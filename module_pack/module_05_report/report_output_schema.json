{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Report Output Schema",
  "description": "OpenClaw 報告模組的統一輸出結構定義，所有報告類型必須嚴格遵循此 schema",
  "version": "1.0",
  "report_types": {
    "daily_brief": {
      "description": "每日摘要報告",
      "type": "object",
      "required": ["title", "date", "topic", "summary", "key_points", "sources", "generated_at"],
      "properties": {
        "title": {
          "type": "string",
          "description": "報告標題，格式：[主題] — 每日摘要"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "報告日期，格式：YYYY-MM-DD",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "topic": {
          "type": "string",
          "description": "報告主題關鍵字"
        },
        "summary": {
          "type": "string",
          "description": "整體摘要，100-200 字",
          "minLength": 100,
          "maxLength": 200
        },
        "key_points": {
          "type": "array",
          "description": "重點清單，3-5 條",
          "items": {
            "type": "string",
            "maxLength": 80
          },
          "minItems": 3,
          "maxItems": 5
        },
        "sources": {
          "type": "array",
          "description": "來源清單",
          "items": {
            "type": "object",
            "required": ["title", "url"],
            "properties": {
              "title": {
                "type": "string",
                "description": "來源標題"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "來源連結"
              }
            }
          },
          "minItems": 1,
          "maxItems": 10
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "報告生成時間，ISO 8601 格式"
        }
      }
    },
    "weekly_report": {
      "description": "週報",
      "type": "object",
      "required": ["title", "week_range", "highlights", "metrics", "next_week_todos", "risks", "generated_at"],
      "properties": {
        "title": {
          "type": "string",
          "description": "報告標題"
        },
        "week_range": {
          "type": "string",
          "description": "週報涵蓋範圍，格式：YYYY-MM-DD ~ YYYY-MM-DD",
          "pattern": "^\\d{4}-\\d{2}-\\d{2} ~ \\d{4}-\\d{2}-\\d{2}$"
        },
        "highlights": {
          "type": "array",
          "description": "本週重點摘要，3-5 條",
          "items": {
            "type": "string",
            "maxLength": 100
          },
          "minItems": 3,
          "maxItems": 5
        },
        "metrics": {
          "type": "object",
          "description": "業務數據",
          "required": ["new_leads", "follow_ups", "conversions", "tasks_completed", "tasks_total"],
          "properties": {
            "new_leads": {
              "type": "number",
              "description": "本週新 Lead 數",
              "minimum": 0
            },
            "follow_ups": {
              "type": "number",
              "description": "本週跟進數",
              "minimum": 0
            },
            "conversions": {
              "type": "number",
              "description": "本週成交數",
              "minimum": 0
            },
            "tasks_completed": {
              "type": "number",
              "description": "本週完成任務數",
              "minimum": 0
            },
            "tasks_total": {
              "type": "number",
              "description": "本週任務總數",
              "minimum": 0
            }
          }
        },
        "next_week_todos": {
          "type": "array",
          "description": "下週待辦事項",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 10
        },
        "risks": {
          "type": "array",
          "description": "風險提醒，含描述和建議動作",
          "items": {
            "type": "string"
          },
          "maxItems": 5
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "報告生成時間，ISO 8601 格式"
        }
      }
    },
    "project_daily": {
      "description": "專案日報",
      "type": "object",
      "required": ["title", "date", "project_name", "progress", "blockers", "tomorrow_plan", "generated_at"],
      "properties": {
        "title": {
          "type": "string",
          "description": "報告標題，格式：[專案名稱] — 專案日報"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "報告日期，格式：YYYY-MM-DD",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "project_name": {
          "type": "string",
          "description": "專案名稱"
        },
        "progress": {
          "type": "array",
          "description": "今日完成事項",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 10
        },
        "blockers": {
          "type": "array",
          "description": "阻礙事項，含影響範圍和需要誰協助",
          "items": {
            "type": "string"
          },
          "maxItems": 5
        },
        "tomorrow_plan": {
          "type": "array",
          "description": "明日計畫",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 5
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "報告生成時間，ISO 8601 格式"
        }
      }
    }
  },
  "output_settings": {
    "description": "全域輸出設定",
    "type": "object",
    "properties": {
      "language": {
        "type": "string",
        "default": "zh-TW",
        "description": "輸出語言"
      },
      "max_summary_length": {
        "type": "number",
        "default": 200,
        "description": "摘要最大字數"
      },
      "max_key_points": {
        "type": "number",
        "default": 5,
        "description": "重點清單最大條數"
      },
      "include_sources": {
        "type": "boolean",
        "default": true,
        "description": "是否包含來源連結"
      },
      "include_disclaimer": {
        "type": "boolean",
        "default": true,
        "description": "是否包含免責聲明（適用於股票/產業觀察類報告）"
      }
    }
  }
}
